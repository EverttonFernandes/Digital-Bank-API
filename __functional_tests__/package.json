{
  "name": "digital-bank-api-functional-tests",
  "version": "0.1.0",
  "description": "Suite funcional da API do banco digital",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "seed": "node seed.js",
    "rollback": "node rollback.js",
    "test": "node runFunctionalTests.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "pg": "^8.13.1",
    "sequelize": "^6.37.3",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "rootDir": ".",
    "testMatch": [
      "**/?(*.)+(spec).js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setup/setup.js"
    ]
  }
}
